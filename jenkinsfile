        stage('AWS'){
            agent{
                docker{
                    image 'amazon/aws-cli:latest'
                    reuseNode true
                    args '--entrypoint=""'
                }
            }
            steps{
                withCredentials([usernamePassword(
                    credentialsId: 'S3AWSCred', 
                    passwordVariable: 'AWS_SECRET_ACCESS_KEY', 
                    usernameVariable: 'AWS_ACCESS_KEY_ID')
                ]) {
                    sh '''
                        aws --version
                        aws s3 ls
                    '''
                }
            }
        }
