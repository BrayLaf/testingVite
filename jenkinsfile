pipeline{
    agent any
    stages{
        stage('Build'){
            agent{
                docker{
                    image 'node:24.14.0'
                    reuseNode true
                }
            }
            steps{
                sh '''
                    ls -la
                    node --version
                    npm --version
                    npm install
                    npm run build
                    ls -la
                '''
            }
        }
        stage('Test'){
            agent{
                docker{
                    image 'node:24.14.0'
                    reuseNode true
                }
            }
            steps{
                sh '''
                    npm test
                '''
            }
        }
        stage('Deploy'){
            agent{
                docker{
                    image 'node:24.14.0'
                    reuseNode true
                }
            }
            steps{
                withCredentials([
                    string(credentialsId: 'netlify-auth-token', variable: 'NETLIFY_AUTH_TOKEN'),
                    string(credentialsId: 'netlify-site-id', variable: 'NETLIFY_SITE_ID')
                ]) {
                    sh '''
                        npx netlify-cli --version
                        npx netlify-cli deploy --prod --dir=dist --site=$NETLIFY_SITE_ID --auth=$NETLIFY_AUTH_TOKEN
                    '''
                }
            }
        }
    }
}